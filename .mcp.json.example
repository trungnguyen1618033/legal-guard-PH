{
  "//": "CockroachDB Cloud Managed MCP Server (feature #3). Copy to .mcp.json (or run the `claude mcp add` command in docs/crdb-features.md) to enable for Claude Code / any MCP client. Read-only by default (mcp:read); blocks DROP/TRUNCATE. Replace {your-cluster-id} with your cluster id (ccloud cluster list -o json → .id). Auth: OAuth (run /mcp → Authenticate) OR add an Authorization: Bearer <service-account-api-key> header (role Cluster Operator).",
  "mcpServers": {
    "cockroachdb-cloud": {
      "type": "http",
      "url": "https://cockroachlabs.cloud/mcp",
      "headers": {
        "mcp-cluster-id": "{your-cluster-id}"
      }
    }
  }
}
