# Sao chép thành .env và điền key thật. KHÔNG commit .env (đã có trong .gitignore).

# --- Qwen (LLM phân tích chính — bắt buộc cho Qwen hackathon) ---
# Qwen Cloud / DashScope endpoint tương thích OpenAI
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max
QWEN_EMBED_MODEL=text-embedding-v4
QWEN_VL_MODEL=qwen3.7-plus
QWEN_RERANK_MODEL=qwen3-rerank

# --- Gemini (≥1 call trong production — bắt buộc cho XPRIZE) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- App ---
DEFAULT_TENANT=VN
KNOWLEDGE_BASE_DIR=knowledge_base
# Cross-encoder rerank. Cách A: Qwen-Rerank API (model qwen3-rerank, Model Studio) — remote, zero-ops.
# Cần QWEN_API_KEY có quyền model qwen3-rerank. Lỗi → tự tắt rerank, hệ thống chạy tiếp bằng BM25+embedding.
# (Nâng cấp B sau: self-host AITeamVN reranker trên GPU — chất lượng pháp-lý-VN cao nhất.)
CROSS_ENCODER_RERANK=true
# Bật citation closure: đi theo dẫn chiếu kéo về điều luật liên quan (Phase 2, offline, không cần key).
CITATION_CLOSURE=false
# Lọc hiệu lực: mặc định true = chỉ trả văn bản còn hiệu lực (theo front-matter 'status' của file KB).
IN_FORCE_FILTER=true
# Gắn căn cứ điều luật (tất định, từ KB) cho mỗi risk/fallback khi soát hợp đồng. Mặc định true.
LEGAL_BASIS_GROUNDING=true

# --- Deploy (prod/ECS) ---
# Tên miền trỏ về IP ECS — Caddy tự xin HTTPS cert. Để trống khi chạy local.
DOMAIN=legalguard.example.com

# --- Database ---
# Local không docker: sqlite (mặc định). Docker compose tự đặt URL postgres (đè dòng này).
DATABASE_URL=sqlite:///data/cases.db

# Chat session store: sql (persist+đa instance) | memory | redis
CONVERSATION_BACKEND=sql
REDIS_URL=

# Observability (Langfuse — rỗng = tắt/NoOp; cần pip install langfuse)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Security ---
# Bật auth + cô lập theo CÔNG TY. Dạng "KEY:ORG_ID:COUNTRY" (vd "k1:acme:VN,k2:globex:VN").
# Rỗng = MỞ (chỉ dev). PROD PHẢI đặt.
API_KEYS=
MAX_UPLOAD_BYTES=10485760

# --- Channels (rỗng = tắt webhook / không gửi reply) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
ZALO_OA_SECRET=
ZALO_APP_ID=
ZALO_ACCESS_TOKEN=
